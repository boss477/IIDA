# Gemini vision (Analyze LLM — used before LM Studio when set)
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-3-flash-preview

# Prefer editing lm_studio.json in this folder (overrides LM_STUDIO_* shell vars when set there).
#
# Local LM Studio (browser → OpenAI-compatible API). Use the /v1 base URL shown in LM Studio.
# Enable CORS in LM Studio if the browser blocks direct calls; otherwise use the proxy below.
VITE_LM_STUDIO_URL=http://10.212.228.25:1234/v1
VITE_LM_STUDIO_MODEL=qwen/qwen3.5-9b

# Optional: use Node proxy instead (avoids browser CORS). Then omit VITE_LM_STUDIO_URL or leave blank.
# Run: set LM_STUDIO_URL=http://10.212.228.25:1234/v1&& set LM_STUDIO_MODEL=qwen/qwen3.5-9b&& npm run analyze-server
# VITE_ANALYZE_API=http://127.0.0.1:8787

# Supabase — xcel project (shearling_catalog + plan_catalog_presets)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_... or legacy anon JWT
# Optional: enable plan raster upload to Storage
# VITE_SUPABASE_STORAGE=1
